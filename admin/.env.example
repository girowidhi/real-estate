# Tobillion Homes Admin — Environment Variables
# Copy to .env.local

# --- Database (Supabase — same as main site) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Admin Auth ---
ADMIN_JWT_SECRET=
ADMIN_SESSION_EXPIRY=24h

# --- Email (for password reset) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@tobillionhomes.co.ke

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://tobillionhomes.co.ke
NEXT_PUBLIC_ADMIN_URL=https://tobillionhomes.co.ke/admin

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=5

# --- Media ---
NEXT_PUBLIC_UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
