# Tobillion Homes Admin — Environment Variables

# --- Database (SQLite) ---
SQLITE_DB_PATH=C:/Users/brax/Desktop/tobi/shared-data/tobillion.db

# --- Admin Auth ---
ADMIN_JWT_SECRET=change-this-to-a-random-secret
ADMIN_SESSION_EXPIRY=24h

# --- Email (for password reset) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@tobillionhomes.co.ke

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3000/admin

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=5

# --- Media ---
NEXT_PUBLIC_UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
